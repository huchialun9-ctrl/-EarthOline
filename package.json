{
  "name": "earth-online",
  "version": "1.0.0",
  "description": "Earth Online - Global Civilization Mining Idle Game",
  "private": true,
  "engines": { "node": "20.x" },
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "node --watch backend/src/server.js",
    "build": "node -e \"const fs=require('fs');const p='client/dist';fs.mkdirSync(p,{recursive:true});fs.readdirSync('client').filter(f=>f!=='dist').forEach(f=>fs.cpSync('client/'+f,p+'/'+f,{recursive:true}))\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.0",
    "express-session": "^1.17.3",
    "leaflet": "^1.9.4",
    "mongoose": "^7.8.0",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4"
  }
}
